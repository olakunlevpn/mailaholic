<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <OutputType>WinExe</OutputType>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>DBSetupQuick</RootNamespace>
    <AssemblyName>DBSetupQuick</AssemblyName>
    <PlatformTarget>x64</PlatformTarget>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
  </PropertyGroup>

  <ItemGroup Condition="Exists('$(MSBuildProjectDirectory)\..\Interop.hMailServer.dll')">
    <Reference Include="Interop.hMailServer">
      <HintPath>$(MSBuildProjectDirectory)\..\Interop.hMailServer.dll</HintPath>
    </Reference>
  </ItemGroup>

</Project>
